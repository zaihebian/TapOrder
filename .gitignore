# =========================
# Root .gitignore (Monorepo: NestJS + Next.js)
# =========================

# --- Node ---
node_modules/

# --- Environments ---
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# --- Logs ---
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors/Tools ---
.vscode/
.idea/
*.swp
*.swo

# --- Build Artifacts ---
dist/
build/
.tmp/
.temp/
tmp/
.cache/
coverage/

# --- TypeScript ---
*.tsbuildinfo

# --- Next.js ---
.next/
.vercel/
.turbo/
out/

# --- Project Specific ---
backend/dist/
frontend/.next/

# --- Misc ---
*.local